{
  "version": 2,
  "routes": [
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/api/resolve", "dest": "/api/resolve.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
