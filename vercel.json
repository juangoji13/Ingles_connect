{
  "version": 2,
  "rewrites": [
    { "source": "/api/admin", "destination": "/api/admin.js" },
    { "source": "/api/resolve", "destination": "/api/resolve.js" },
    { "source": "/admin", "destination": "/public/admin.html" },
    { "source": "/css/(.*)", "destination": "/public/css/$1" },
    { "source": "/js/(.*)", "destination": "/public/js/$1" },
    { "source": "/((?!api/).*)", "destination": "/public/$1" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
